            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"query\": \"query Projects($pagination: ProjectsPaginationDto) {\\n  projects(pagination: $pagination) {\\n    items {\\n      id\\n      title\\n      width\\n      height\\n      thumbnailUrl\\n      createdAt\\n      updatedAt\\n    }\\n    total\\n    page\\n    totalPages\\n  }\\n}\",\n  \"variables\": {\n    \"pagination\": { \"page\": 1, \"limit\": 20 }\n  }\n}"
            }
          }
        },
        {
          "name": "Get Project by ID",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
