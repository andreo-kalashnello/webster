{
  "info": {
    "name": "Webster Backend",
    "_postman_id": "webster-backend-v2",
    "description": "GraphQL API для Webster Backend.\n\nВсе GraphQL запросы — POST {{baseUrl}}/graphql с Content-Type: application/json.\nАутентификация через HttpOnly куки (access_token, refresh_token) — Postman сохраняет их автоматически.\n\nПеременные коллекции:\n  baseUrl       — http://localhost:4000\n  projectId     — заполняется автоматически после Create Project\n  versionId     — заполняется автоматически после Create Version\n  templateId    — заполняется автоматически после Create User Template\n  shareToken    — заполняется автоматически после Create Share Link",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000",
      "type": "string"
    },
    {
      "key": "projectId",
      "value": "",
      "type": "string"
    },
    {
      "key": "versionId",
      "value": "",
      "type": "string"
    },
    {
      "key": "templateId",
      "value": "",
      "type": "string"
    },
    {
      "key": "shareToken",
      "value": "",
      "type": "string"
    }
  ],
