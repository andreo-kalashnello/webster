              "raw": "{\n  \"query\": \"mutation UpdateProject($id: ID!, $input: UpdateProjectDto!) {\\n  updateProject(id: $id, input: $input) {\\n    id\\n    title\\n    width\\n    height\\n    updatedAt\\n  }\\n}\",\n  \"variables\": {\n    \"id\": \"{{projectId}}\",\n    \"input\": {\n      \"title\": \"Renamed Canvas\",\n      \"width\": 1280,\n      \"height\": 720\n    }\n  }\n}"
            }
          }
        },
