NODE_ENV=development
PORT=4000

# MongoDB
MONGODB_URI=mongodb://webster:webster@localhost:27017/webster?authSource=admin

# JWT
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_REFRESH_DAYS=7

# SMTP (optional — falls back to console.log if SMTP_HOST is not set)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Webster <no-reply@webster.local>

# App
FRONTEND_URL=http://localhost:5173
GRAPHQL_PLAYGROUND=false
APP_NAME=Webster

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
